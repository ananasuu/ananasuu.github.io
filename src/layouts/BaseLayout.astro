---
import BasicLayout from "@ninumakes/ui/BasicLayout.astro"
import { siteConfig } from '@/config/site';
import { getLocaleFromUrl } from '@/utils/i18n/i18n';
import { useTranslations } from '@/utils/i18n/ui';
import type { BaseLayoutProps } from '@/types';
import "../../public/assets/styles/index.css"

const { title = siteConfig.title, header, description = siteConfig.meta.description.en } = Astro.props as BaseLayoutProps;

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = useTranslations(locale);

---

<BasicLayout
title={title}
  description={description}
  siteUrl={siteConfig.url}
  author={siteConfig.author}
  keywords={siteConfig.meta.keywords}
  header={header}
  >
<slot />
</BasicLayout>